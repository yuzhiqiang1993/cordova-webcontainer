<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    tools:context="com.yzq.demo.activity.MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="导航与页面集成"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_cordova_activity_sample"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="继承自 CordovaActivity (传统)"
                android:backgroundTint="#007AFF"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_container_activity_sample"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="继承自 WebContainerActivity (推荐)"
                android:backgroundTint="#009688"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_fragment_sample"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="Fragment 中加载 Vant Uploader"
                android:backgroundTint="#FF6F00"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_geolocation_sample"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:text="独立 Geolocation 定位测试示例"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="内嵌 Cordova 原生 View 组件"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!--基于 Cordova 封装的 web 容器控件，包裹至高级卡片中展示-->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <com.yzq.cordova_webcontainer.CordovaWebContainer
                    android:id="@+id/web_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
